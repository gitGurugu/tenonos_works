$(eval $(call addlib_s,libtnschedprio,$(CONFIG_LIBTNSCHEDPRIO)))

CINCLUDES-$(CONFIG_LIBTNSCHEDPRIO)     += -I$(LIBTNSCHEDPRIO_BASE)/include
CXXINCLUDES-$(CONFIG_LIBTNSCHEDPRIO)   += -I$(LIBTNSCHEDPRIO_BASE)/include

LIBTNSCHEDPRIO_SRCS-y += $(LIBTNSCHEDPRIO_BASE)/schedprio.c

ifneq ($(filter y,$(CONFIG_LIBTNSCHEDPRIO_TEST) $(CONFIG_LIBUKTEST_ALL)),)
LIBTNSCHEDPRIO_SRCS-y += $(LIBTNSCHEDPRIO_BASE)/tests/test_tnschedprio.c
endif
