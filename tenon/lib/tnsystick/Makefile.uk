$(eval $(call addlib_s,libtnsystick,$(CONFIG_LIBTNSYSTICK)))

ASINCLUDES-$(CONFIG_LIBTNSYSTICK)  += -I$(LIBTNSYSTICK_BASE)/include
CINCLUDES-$(CONFIG_LIBTNSYSTICK)   += -I$(LIBTNSYSTICK_BASE)/include
CXXINCLUDES-$(CONFIG_LIBTNSYSTICK) += -I$(LIBTNSYSTICK_BASE)/include

LIBTNSYSTICK_CINCLUDES-y += -I$(CONFIG_UK_BASE)/plat/common/include

LIBTNSYSTICK_SRCS-$(CONFIG_LIBTNSYSTICK) += $(LIBTNSYSTICK_BASE)/tnsystick.c
